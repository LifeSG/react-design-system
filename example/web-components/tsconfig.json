{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "react",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "paths": {
            "@lifesg/react-design-system": ["../../src/index.ts"],
            "@lifesg/react-design-system/*": ["../../src/*"]
        }
    },
    "include": ["./**/*"]
}
