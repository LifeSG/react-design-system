{
    "compilerOptions": {
        "target": "ES2021",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2021", "DOM", "DOM.Iterable"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "verbatimModuleSyntax": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "paths": {
            "@lib/*": ["./src/*"]
        }
    },
    "include": ["src", "demo"]
}
