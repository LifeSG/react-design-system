{
    "name": "@lifesg/react-design-system",
    "version": "4.0.0-alpha.4",
    "description": "A component design system for LifeSG web apps",
    "main": "dist/cjs/index.js",
    "module": "dist/index.js",
    "typings": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/cjs/index.js",
            "default": "./dist/index.js"
        },
        "./web-components": {
            "types": "./dist/web-components.d.ts",
            "import": "./dist/web-components.js",
            "require": "./dist/cjs/web-components.js",
            "default": "./dist/web-components.js"
        },
        "./vue": {
            "types": "./dist/vue-components.d.ts",
            "import": "./dist/vue-components.js",
            "require": "./dist/cjs/vue-components.js",
            "default": "./dist/vue-components.js"
        }
    },
    "bin": {
        "lifesg-react-design-system": "./codemods/run-codemod.js"
    },
    "scripts": {
        "build": "npm run rollup",
        "rollup": "rm -rf dist && rollup -c",
        "build:web-components-lib": "node scripts/generate-wc-entries.mjs && BUILD_WEB_COMPONENTS=true npm run rollup && rm -f src/web-components.ts",
        "build:vue-components-lib": "node scripts/vue-components.mjs generate && BUILD_VUE_COMPONENTS=true npm run rollup && node scripts/vue-components.mjs clean",
        "build-lib": "./scripts/build.sh",
        "publish-lib": "npm publish ./dist",
        "start": "rollup -c -w",
        "test": "jest --coverage",
        "test-watch": "jest --watch",
        "test-e2e": "npm run test-e2e:setup && playwright test --ui",
        "test-e2e:docker": "docker compose up --build",
        "test-e2e:setup": "./scripts/e2e-setup.sh",
        "test-e2e-ci": "npm run test-e2e:setup && ./scripts/e2e-ci.sh",
        "prepare": "(test -d ./.git && npx husky install) || true",
        "postinstall": "patch-package",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "codemod": "ENV=dev npx tsx codemods/run-codemod.ts",
        "lint": "npm run lint:js && npm run lint:css",
        "lint:js": "eslint '**/*.{ts,tsx,js,jsx}' && npm --prefix e2e/nextjs-app run lint:src",
        "lint:js:fix": "eslint '**/*.{ts,tsx,js,jsx}' --fix && npm --prefix e2e/nextjs-app run lint:src:fix",
        "lint:css": "stylelint '**/*.css'",
        "lint:css:fix": "stylelint '**/*.css' --fix",
        "test:eslint-rules": "node tests/eslint-rules/run-eslint-rule-tests.mjs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/LifeSG/react-design-system.git"
    },
    "keywords": [
        "design-system"
    ],
    "author": "LifeSG",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/LifeSG/react-design-system/issues"
    },
    "homepage": "https://github.com/LifeSG/react-design-system#readme",
    "dependencies": {
        "@react-aria/live-announcer": "^3.4.4",
        "@react-spring/web": "^10.0.1",
        "clsx": "^2.1.1",
        "fabric": "^7.2.0",
        "immer": "^10.0.2",
        "react-to-webcomponent": "^2.0.1",
        "react-slider": "^2.0.6",
        "react-virtuoso": "^4.12.5",
        "react-zoom-pan-pinch": "^3.3.0",
        "veaury": "^2.6.3"
    },
    "devDependencies": {
        "@babel/core": "^7.25.2",
        "@babel/preset-env": "^7.16.11",
        "@babel/preset-react": "^7.24.7",
        "@babel/preset-typescript": "^7.24.7",
        "@dnd-kit/core": "^6.0.8",
        "@dnd-kit/sortable": "^7.0.2",
        "@dnd-kit/utilities": "^3.2.2",
        "@eslint/js": "^9.39.1",
        "@floating-ui/react": "^0.26.23",
        "@govtechsg/sgds-web-component": "^3.0.6",
        "@inquirer/prompts": "^7.0.0",
        "@lifesg/react-icons": "^1.12.0",
        "@linaria/core": "^7.0.0",
        "@playwright/test": "^1.58.2",
        "@rollup/plugin-commonjs": "^25.0.7",
        "@rollup/plugin-image": "^3.0.3",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^15.2.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@storybook-community/storybook-dark-mode": "^7.1.0",
        "@storybook/addon-a11y": "^10.2.10",
        "@storybook/addon-docs": "^10.2.10",
        "@storybook/addon-links": "^10.2.10",
        "@storybook/addon-themes": "^10.2.10",
        "@storybook/addon-webpack5-compiler-swc": "^4.0.2",
        "@storybook/react-webpack5": "^10.2.10",
        "@stylistic/stylelint-plugin": "^5.0.1",
        "@testing-library/jest-dom": "^6.0.0",
        "@testing-library/react": "^12.1.4",
        "@testing-library/user-event": "^14.5.2",
        "@types/jest": "^30.0.0",
        "@types/jscodeshift": "^0.11.11",
        "@types/lodash": "^4.14.180",
        "@types/node": "^22.15.14",
        "@types/react": "^17.0.43",
        "@types/react-dom": "^17.0.14",
        "@types/react-slider": "^1.3.6",
        "@typescript-eslint/eslint-plugin": "^8.46.2",
        "@typescript-eslint/parser": "^8.46.2",
        "@wyw-in-js/rollup": "^1.0.6",
        "@wyw-in-js/shared": "^1.1.0",
        "@wyw-in-js/transform": "^1.1.0",
        "@wyw-in-js/webpack-loader": "^1.0.6",
        "dayjs": "^1.11.3",
        "dedent": "^1.7.0",
        "dompurify": "^3.2.5",
        "eslint": "^9.39.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-storybook": "10.1.11",
        "globals": "^16.5.0",
        "husky": "^7.0.4",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^30.0.0",
        "jest-canvas-mock": "^2.3.1",
        "jest-environment-jsdom": "^30.0.0",
        "jest-junit": "^17.0.0",
        "jscodeshift": "^17.3.0",
        "lint-staged": "^12.3.7",
        "lodash": "^4.17.21",
        "lottie-colorify": "^0.8.0",
        "lottie-react": "^2.3.1",
        "patch-package": "^8.0.0",
        "postcss": "^8.4.38",
        "postcss-import": "^16.1.0",
        "prettier": "^2.6.1",
        "pretty-quick": "^3.1.3",
        "react": "^17.0.2",
        "react-dom": "^17.0.2",
        "react-dropzone": "^14.2.3",
        "react-intersection-observer": "^9.5.2",
        "react-resize-detector": "^10.0.1",
        "remark-gfm": "^4.0.0",
        "rollup": "^4.34.9",
        "rollup-plugin-copy": "^3.5.0",
        "rollup-plugin-exclude-dependencies-from-bundle": "^1.1.24",
        "rollup-plugin-generate-package-json": "^3.2.0",
        "rollup-plugin-lib-style": "^2.4.7",
        "rollup-plugin-typescript2": "^0.37.0",
        "storybook": "^10.2.10",
        "stylelint": "^17.4.0",
        "stylelint-config-recess-order": "^7.6.1",
        "stylelint-config-standard": "^40.0.0",
        "typescript": "^5.7.3",
        "vue": "^3.5.39"
    },
    "peerDependencies": {
        "@floating-ui/react": ">=0.26.23 <1.0.0",
        "@lifesg/react-icons": "^1.5.0",
        "react": "^17.0.2 || ^18.0.0 || ^19.0.0",
        "react-dom": "^17.0.2 || ^18.0.0 || ^19.0.0",
        "vue": "^3.4.0"
    },
    "peerDependenciesMeta": {
        "vue": {
            "optional": true
        }
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.54.0",
        "@swc/core-linux-arm64-gnu": "^1.15.11"
    },
    "overrides": {
        "react-resize-detector": {
            "react": "$react",
            "react-dom": "$react-dom"
        }
    },
    "lint-staged": {
        "*.{tsx,ts}": [
            "eslint --fix"
        ],
        "e2e/nextjs-app/src/**/*.{ts,tsx,js,jsx}": [
            "npm --prefix e2e/nextjs-app run lint:staged:fix --"
        ],
        "!(native-ports)/**/*.{css,module.css}": [
            "stylelint --fix"
        ]
    }
}
